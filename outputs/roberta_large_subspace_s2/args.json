{
  "seed": 43,
  "output_dir": "outputs/roberta_large_subspace_s2",
  "algorithm": "subspace_reg",
  "model_name": "FacebookAI/roberta-large",
  "torch_dtype": "float32",
  "gradient_checkpointing": true,
  "load_in_4bit": false,
  "trust_remote_code": false,
  "lora_rank": 8,
  "lora_alpha": 16,
  "lora_dropout": 0.05,
  "num_clients": 10,
  "client_fraction": 0.3,
  "num_rounds": 20,
  "local_epochs": 1,
  "max_local_steps": 30,
  "partition_type": "dirichlet",
  "partition_field": "activity_label",
  "dirichlet_alpha": 0.3,
  "min_client_size": 8,
  "max_train_samples": 8000,
  "max_eval_samples": 1000,
  "max_length": 256,
  "per_device_train_batch_size": 1,
  "per_device_eval_batch_size": 2,
  "gradient_accumulation_steps": 8,
  "learning_rate": 0.0001,
  "weight_decay": 0.0,
  "max_grad_norm": 0.5,
  "mu": 0.05,
  "alpha": 0.01,
  "lambda_reg": 1e-05,
  "checkpoint_every": 1,
  "max_effective_lora_update_norm": 15.0
}